Given php:
  <?php

  class SomeClass
  {
      public static function someMethod()
      {
          $someVariable = 'some variable value';
      }
  }

Do:
  /someVariable\<Enter>
  ;ep

Expect:
  <?php

  class SomeClass
  {
      private static $someVariable;

      public static function someMethod()
      {
          self::$someVariable = 'some variable value';
      }
  }
