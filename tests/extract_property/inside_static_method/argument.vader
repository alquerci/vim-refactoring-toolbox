Given php:
  <?php

  class SomeClass
  {
      public static function someMethod($someVariable)
      {
          $anotherVariable = $someVariable;
      }
  }

Do:
  /someVariable\<Enter>
  ;ep

Expect:
  <?php

  class SomeClass
  {
      private static $someVariable;

      public static function someMethod($someVariable)
      {
          self::$someVariable = $someVariable;

          $anotherVariable = self::$someVariable;
      }
  }
